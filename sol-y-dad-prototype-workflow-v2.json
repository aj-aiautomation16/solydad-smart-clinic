        "jsCode": "const records = $input.all();\nconst webhookData = $('Filter Messages').first().json;\n\nlet patientName = '';\nlet phoneNumber = '';\nlet hasActiveAppointment = 'NO';\nlet appointmentDetails = '';\n\nfor (const record of records) {\n  const r = record.json || {};\n  if (!patientName && r.patient_name) patientName = r.patient_name;\n  if (!phoneNumber && r.phone_number) phoneNumber = r.phone_number;\n  if (!appointmentDetails && r.appointment_date_time) {\n    const apptDate = new Date(r.appointment_date_time);\n    if (apptDate > new Date()) {\n      hasActiveAppointment = 'YES';\n      appointmentDetails = r.appointment_date_time;\n    }\n  }\n}\n\nreturn [{\n  json: {\n    body: webhookData.body,\n    query: webhookData.query,\n    headers: webhookData.headers,\n    patient_name: patientName || 'New Patient',\n    phone_number: phoneNumber || '',\n    has_active_appointment: hasActiveAppointment,\n    appointment_details: appointmentDetails\n  }\n}];"
      },
